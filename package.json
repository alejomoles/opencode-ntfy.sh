{
  "name": "opencode-ntfy.sh",
  "version": "1.1.0",
  "description": "OpenCode plugin that sends push notifications via ntfy.sh",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/ tests/",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@opencode-ai/plugin": "^1.16.2",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "msw": "^2.14.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist",
    "notification-ntfy.schema.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lannuttia/opencode-ntfy.sh.git"
  },
  "author": "Anthony Lannutti <lannuttia@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/lannuttia/opencode-ntfy.sh#readme",
  "bugs": "https://github.com/lannuttia/opencode-ntfy.sh/issues",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "ntfy",
    "ntfy.sh",
    "notifications",
    "push-notifications",
    "ai",
    "coding-assistant",
    "plugin"
  ],
  "dependencies": {
    "iso8601-duration": "^2.1.3",
    "opencode-notification-sdk": "^1.1.0"
  }
}
